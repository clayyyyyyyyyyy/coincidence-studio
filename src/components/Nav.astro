---
const currentPath = Astro.url.pathname;

const items = [
  { href: '/', label: 'Home', planet: 'sun' },
  { href: '/work', label: 'Work', planet: 'mercury' },
  { href: '/curation', label: 'Exhibitions', planet: 'venus' },
  { href: '/writing', label: 'Writing', planet: 'earth' },
  { href: '/contact', label: 'Contact', planet: 'mars' },
];
---

<nav class="badge-nav" id="badge-nav" aria-label="Site navigation">
  {items.map((item, i) => (
    <div class="badge-item" style={`--i: ${i}`}>
      <a
        href={item.href}
        class:list={['badge-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
        tabindex={i === 0 ? undefined : -1}
      >
        <span class="badge-label">{item.label}</span>
      </a>
      <button
        class="badge-circle"
        data-index={i}
        data-planet={item.planet}
        aria-label={i === 0 ? 'Toggle menu' : item.label}
      >
        <canvas class="planet-canvas" data-planet={item.planet}></canvas>
      </button>
    </div>
  ))}
</nav>

<style>
  .badge-nav {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
    pointer-events: none;
  }

  .badge-item {
    display: flex;
    align-items: center;
    gap: 10px;
    pointer-events: auto;
  }

  /* Planets 2–5: stacked behind planet 1 when closed */
  .badge-item:nth-child(n+2) {
    opacity: 0;
    transform: translateY(calc(-1 * var(--i) * (24px + 10px)));
    pointer-events: none;
    transition:
      transform 0.3s cubic-bezier(0.6, 0, 0.4, 1),
      opacity 0.15s ease;
    transition-delay: 0.12s;
  }

  /* When open: planets drop to natural position */
  .badge-nav.open .badge-item:nth-child(n+2) {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    transition:
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.2s ease;
    transition-delay: calc(var(--i) * 50ms);
  }

  /* Badge circle — planet container */
  .badge-circle {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: transparent;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
    position: relative;
    z-index: 2;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .badge-circle:hover {
    transform: scale(1.15);
  }

  .badge-circle:active {
    transform: scale(0.95);
  }

  .planet-canvas {
    width: 32px !important;
    height: 32px !important;
    border-radius: 50%;
    display: block;
    pointer-events: none;
  }

  /* Badge labels — hidden by default */
  .badge-label {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #1A1A1A;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(8px);
    pointer-events: none;
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
    transition-delay: 0s;
  }

  /* When open: labels slide in */
  .badge-nav.open .badge-label {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
    transition-delay: calc(0.2s + var(--i) * 40ms);
  }

  /* Link wrapper */
  .badge-link {
    border-bottom: none;
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .badge-link:hover {
    border-bottom: none;
  }

  .badge-link:hover .badge-label {
    color: #6B6B6B;
  }

  /* Fullbleed (homepage) night-mode label color */
  :global(body.fullbleed.night-mode) .badge-label {
    color: #fff;
    transition: opacity 0.25s ease, transform 0.25s ease, color 0.8s ease;
  }

  :global(body.fullbleed.night-mode) .badge-link:hover .badge-label {
    color: rgba(255, 255, 255, 0.6);
  }

  :global(body.fullbleed:not(.night-mode)) .badge-label {
    transition: opacity 0.25s ease, transform 0.25s ease, color 0.8s ease;
  }

  .badge-nav.open .badge-link {
    tabindex: 0;
  }

  @media (max-width: 768px) {
    .badge-nav {
      top: 12px;
      right: 12px;
    }
  }
</style>

<script>
  import * as THREE from 'three';

  // --- Three.js Planet Rendering ---
  const PLANET_SIZE = 24;

  const planetConfigs = [
    { name: 'sun', texture: '/textures/sun.jpg', emissive: true, speed: 0.003 },
    { name: 'mercury', texture: '/textures/mercury.jpg', emissive: false, speed: 0.008 },
    { name: 'venus', texture: '/textures/venus.jpg', emissive: false, speed: 0.006 },
    { name: 'earth', texture: '/textures/earth.jpg', emissive: false, speed: 0.005 },
    { name: 'mars', texture: '/textures/mars.jpg', emissive: false, speed: 0.007 },
  ];

  const textureLoader = new THREE.TextureLoader();

  // Each planet gets its own tiny renderer targeting its canvas directly
  const planetData = planetConfigs.map((p) => {
    const canvas = document.querySelector(`.planet-canvas[data-planet="${p.name}"]`) as HTMLCanvasElement;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const renderSize = PLANET_SIZE * dpr;
    canvas.width = renderSize;
    canvas.height = renderSize;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    // Pass false to prevent Three.js from setting canvas.style (which breaks CSS layout)
    renderer.setSize(renderSize, renderSize, false);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.z = 2.6;

    const geometry = new THREE.SphereGeometry(1, 32, 32);
    let material: THREE.Material;
    if (p.emissive) {
      material = new THREE.MeshBasicMaterial({ map: textureLoader.load(p.texture) });
    } else {
      material = new THREE.MeshStandardMaterial({ map: textureLoader.load(p.texture) });
      const light = new THREE.DirectionalLight(0xffffff, 2.5);
      light.position.set(3, 1, 4);
      scene.add(light);
      scene.add(new THREE.AmbientLight(0x404040, 1.0));
    }

    const mesh = new THREE.Mesh(geometry, material);
    mesh.rotation.x = 0.15;
    scene.add(mesh);

    return { renderer, scene, camera, mesh, speed: p.speed };
  });

  function animate() {
    requestAnimationFrame(animate);
    planetData.forEach((pd) => {
      pd.mesh.rotation.y += pd.speed;
      pd.renderer.render(pd.scene, pd.camera);
    });
  }

  animate();

  // --- Navigation Logic ---
  const nav = document.getElementById('badge-nav');
  if (!nav) throw new Error('badge-nav not found');

  const triggerCircle = nav.querySelector('.badge-item:first-child .badge-circle') as HTMLButtonElement;
  const allCircles = nav.querySelectorAll('.badge-circle');
  const allLinks = nav.querySelectorAll('.badge-link');
  let isOpen = false;
  let justToggled = false;

  const isViewerPage = /^\/work\/generative\/.+/.test(window.location.pathname);
  const isWorkPage = window.location.pathname === '/work' || window.location.pathname === '/work/';

  function toggle() {
    isOpen = !isOpen;
    nav.classList.toggle('open', isOpen);

    justToggled = true;
    setTimeout(() => { justToggled = false; }, 300);

    allLinks.forEach((link, i) => {
      (link as HTMLAnchorElement).tabIndex = isOpen ? 0 : (i === 0 ? 0 : -1);
    });
  }

  function handleBadgeOne(e: Event) {
    e.preventDefault();
    e.stopPropagation();
    if (isViewerPage) {
      window.location.href = '/work';
    } else if (isWorkPage && (window as any).isViewerOpen && (window as any).isViewerOpen()) {
      (window as any).closeViewer();
    } else {
      toggle();
    }
  }

  allCircles.forEach((circle, i) => {
    circle.addEventListener('touchend', (e) => {
      e.preventDefault();
      e.stopPropagation();

      if (i === 0) {
        handleBadgeOne(e);
      } else if (isOpen) {
        const link = circle.closest('.badge-item')?.querySelector('.badge-link') as HTMLAnchorElement;
        if (link) window.location.href = link.href;
      }
    });

    circle.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();

      if (i === 0) {
        handleBadgeOne(e);
      } else if (isOpen) {
        const link = circle.closest('.badge-item')?.querySelector('.badge-link') as HTMLAnchorElement;
        if (link) window.location.href = link.href;
      }
    });
  });

  allLinks.forEach((link, i) => {
    if (i === 0) return;
    link.addEventListener('touchend', (e) => {
      if (!isOpen) e.preventDefault();
      e.stopPropagation();
    });
  });

  document.addEventListener('click', (e) => {
    if (isOpen && !justToggled && !nav.contains(e.target as Node)) {
      toggle();
    }
  });
  document.addEventListener('touchend', (e) => {
    if (isOpen && !justToggled && !nav.contains(e.target as Node)) {
      toggle();
    }
  });

  nav.addEventListener('mousedown', (e) => e.stopPropagation());
  nav.addEventListener('touchstart', (e) => e.stopPropagation(), { passive: true });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      toggle();
      triggerCircle.focus();
    }
  });
</script>
