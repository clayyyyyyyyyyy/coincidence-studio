---
import Base from '../layouts/Base.astro';
---

<Base title="Exhibitions" description="Exhibition history by Clay Devlin." fullbleed>
  <div class="construction">
    <img src="/images/construction-1.jpg" alt="Under construction" />
    <p class="construction-text">Under construction... check back in a few days :)</p>
  </div>
</Base>

<style>
  .construction {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .construction img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .construction-text {
    position: relative;
    z-index: 1;
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
    font-size: 1.1rem;
    color: #fff;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.8rem 1.6rem;
    border-radius: 12px;
    max-width: none;
  }

  :global(body) {
    overflow: hidden;
  }

  :global(main) {
    padding: 0 !important;
  }

  :global(.site-footer) {
    display: none;
  }
</style>
