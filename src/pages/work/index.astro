---
import Base from '../../layouts/Base.astro';

const categories = [
  { slug: 'generative-interactive', label: 'Creative Coding', preview: 'sketch' },
  { slug: 'synthetic-video', label: 'Synthetic Video', preview: 'video', file: '/work/synthetic-video/ClayDevlin_SubwayDaydream_1x1_web.mp4' },
  { slug: 'painting', label: 'Painting', preview: 'image', file: '/work/painting/Devlin_Clay_1.jpeg' },
  { slug: 'mixed-media', label: 'Mixed Media', preview: 'image', file: '/work/mixed-media/IMG_8051.jpg' },
  { slug: 'film-photography', label: 'Film Photography', preview: 'image', file: '/work/film-photography/bound.jpg' },
  { slug: 'client-work', label: 'Client Work', preview: 'video', file: '/work/client-work/steps-instrumental_web.mp4' },
];
---

<Base title="Work" description="Work by Clay Devlin." fullbleed>
  <div class="work-page">
    <div class="work-grid">
      {categories.map((cat) => (
        <div class="work-item" data-category={cat.slug}>
          <div class="work-thumb">
            {cat.preview === 'sketch' ? (
              <iframe
                id="icon-sketch"
                class="thumb-iframe"
                loading="lazy"
                scrolling="no"
              ></iframe>
            ) : cat.preview === 'video' ? (
              <video
                class="thumb-media"
                src={cat.file}
                autoplay
                loop
                muted
                playsinline
              ></video>
            ) : (
              <img
                class="thumb-media"
                src={cat.file}
                alt={cat.label}
                loading="lazy"
              />
            )}
          </div>
          <span class="work-label">{cat.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Fullscreen viewer overlay -->
  <div class="viewer-overlay" id="viewer-overlay">
    <iframe id="viewer-iframe" class="viewer-iframe" scrolling="no"></iframe>
    <div class="viewer-controls">
      <button class="viewer-arrow viewer-prev" id="viewer-prev" aria-label="Previous">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M15 5L8 12L15 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="viewer-arrow viewer-next" id="viewer-next" aria-label="Next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</Base>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.11.1/p5.min.js"></script>
<script is:inline src="/sketches/clouds.js"></script>

<script is:inline>
(function() {
  var sketches = [
    'Beziorb', 'Circles', 'Eigenfield', 'Hearth', 'Hive', 'Hypertorus',
    'Julia', 'Lightspeed', 'Portiere', 'Puddle', 'Swirl', 'Tesseractal'
  ];

  var basePath = '/work/generative-interactive/';
  var currentIndex = 0;

  var randomIndex = Math.floor(Math.random() * sketches.length);
  currentIndex = randomIndex;
  var iconIframe = document.getElementById('icon-sketch');
  if (iconIframe) {
    iconIframe.src = basePath + sketches[randomIndex] + '.html';
  }

  var overlay = document.getElementById('viewer-overlay');
  var viewerIframe = document.getElementById('viewer-iframe');
  var prevBtn = document.getElementById('viewer-prev');
  var nextBtn = document.getElementById('viewer-next');

  function openViewer(index) {
    currentIndex = index;
    viewerIframe.src = basePath + sketches[currentIndex] + '.html';
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
    // Pause cloud shader to free GPU for the sketch
    if (window.pauseClouds) window.pauseClouds();
  }

  function closeViewer() {
    overlay.classList.remove('active');
    setTimeout(function() {
      if (!overlay.classList.contains('active')) {
        viewerIframe.src = 'about:blank';
      }
    }, 400);
    document.body.style.overflow = '';
    // Resume cloud shader
    if (window.resumeClouds) window.resumeClouds();
  }

  // Expose closeViewer so the Nav badge "1" can close the viewer
  window.closeViewer = closeViewer;
  window.isViewerOpen = function() { return overlay.classList.contains('active'); };

  function navigate(dir) {
    currentIndex = (currentIndex + dir + sketches.length) % sketches.length;
    viewerIframe.src = basePath + sketches[currentIndex] + '.html';
  }

  var ccIcon = document.querySelector('[data-category="generative-interactive"]');
  if (ccIcon) {
    ccIcon.addEventListener('mousedown', function(e) {
      e.preventDefault();
      e.stopPropagation();
      window._navClicked = true;
      setTimeout(function() { window._navClicked = false; }, 100);
      openViewer(currentIndex);
    });
    ccIcon.addEventListener('touchstart', function(e) {
      e.preventDefault();
      e.stopPropagation();
      window._navClicked = true;
      setTimeout(function() { window._navClicked = false; }, 100);
      openViewer(currentIndex);
    }, { passive: false });
  }

  prevBtn.addEventListener('mousedown', function(e) { e.stopPropagation(); });
  prevBtn.addEventListener('click', function(e) { e.stopPropagation(); navigate(-1); });
  prevBtn.addEventListener('touchend', function(e) { e.preventDefault(); e.stopPropagation(); navigate(-1); }, { passive: false });
  nextBtn.addEventListener('mousedown', function(e) { e.stopPropagation(); });
  nextBtn.addEventListener('click', function(e) { e.stopPropagation(); navigate(1); });
  nextBtn.addEventListener('touchend', function(e) { e.preventDefault(); e.stopPropagation(); navigate(1); }, { passive: false });
  overlay.addEventListener('mousedown', function(e) { e.stopPropagation(); });
  overlay.addEventListener('touchstart', function(e) { e.stopPropagation(); }, { passive: true });

  document.addEventListener('keydown', function(e) {
    if (!overlay.classList.contains('active')) return;
    if (e.key === 'Escape') closeViewer();
    if (e.key === 'ArrowLeft') navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  });

  if (iconIframe) {
    iconIframe.style.pointerEvents = 'none';
  }
})();
</script>

<style>
  :global(body.fullbleed) {
    --hero-text: #1A1A1A;
    --hero-shadow: 0 0 0 transparent;
    overflow: hidden;
    background: transparent;
    transition: color 0.8s ease;
  }

  :global(body.fullbleed.night-mode) {
    --hero-text: #fff;
    --hero-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
  }

  :global(body.fullbleed canvas.p5Canvas) {
    position: fixed !important;
    top: 0;
    left: 0;
    width: 100vw !important;
    height: 100vh !important;
    z-index: 0;
  }

  :global(body.fullbleed main) {
    background: transparent;
    padding: 0;
  }

  :global(body.fullbleed .site-footer) {
    display: none;
  }

  .work-page {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    padding: 2rem;
    max-width: 720px;
  }

  .work-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
  }

  .work-thumb {
    position: relative;
    width: clamp(100px, 18vw, 180px);
    height: clamp(100px, 18vw, 180px);
    border-radius: 22.37%;
    overflow: hidden;
    transition: transform 0.2s ease;
    background: rgba(255, 255, 255, 0.08);
  }

  .work-item:hover .work-thumb {
    transform: scale(1.04);
  }

  .work-item:active .work-thumb {
    transform: scale(0.97);
  }

  .thumb-media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumb-iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 400%;
    height: 400%;
    border: none;
    transform: scale(0.25);
    transform-origin: top left;
    pointer-events: none;
  }

  .work-label {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(0.7rem, 1.4vw, 0.85rem);
    font-weight: 400;
    color: var(--hero-text);
    text-shadow: var(--hero-shadow);
    text-align: center;
    letter-spacing: 0.01em;
    transition: color 0.8s ease, text-shadow 0.8s ease;
  }

  /* Viewer overlay */
  .viewer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .viewer-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  .viewer-iframe {
    width: 100%;
    height: 100%;
    border: none;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }

  .viewer-controls {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .viewer-arrow {
    z-index: 10;
    background: none;
    border: none;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.4);
    transition: color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .viewer-arrow:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  @media (max-width: 768px) {
    .viewer-controls {
      bottom: 40px;
      gap: 2rem;
    }
    .viewer-arrow {
      width: 56px;
      height: 56px;
    }
  }

  @media (max-width: 600px) {
    .work-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }
</style>
