---
import Base from '../layouts/Base.astro';
---

<Base title="Clay Devlin" fullbleed>
  <div class="hero">
    <div class="hero-content">
      <h1>Clay Devlin</h1>
      <div class="bio">
        <p>Generative artist and creative technologist based in New York.</p>
        <p>Born in Louisville, Kentucky, the youngest in a family of artists. Moved through film photography, mixed media, and painting before arriving at creative coding and computational systems as a primary way of working.</p>
        <p>Creates ambient, abstract, evolving systems using p5.js and WebGL that unfold over time and respond to interaction. Most are developed on mobile and shaped by the conditions of everyday screen use.</p>
        <p>Exhibited internationally, including at Beyond Basel in Miami, Primavera Digitale in Florence, and across New York. Founder of Sanctum.</p>
      </div>
    </div>
  </div>
</Base>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.11.1/p5.min.js"></script>
<script is:inline src="/sketches/clouds.js"></script>

<style>
  :global(body.fullbleed) {
    --hero-text: #1A1A1A;
    --hero-shadow: 0 0 0 transparent;
    overflow: hidden;
    background: transparent;
    transition: color 0.8s ease;
  }

  :global(body.fullbleed.night-mode) {
    --hero-text: #fff;
    --hero-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
  }

  :global(body.fullbleed canvas) {
    position: fixed !important;
    top: 0;
    left: 0;
    width: 100vw !important;
    height: 100vh !important;
    z-index: 0;
  }

  :global(body.fullbleed main) {
    background: transparent;
    padding: 0;
  }

  :global(body.fullbleed .site-footer) {
    display: none;
  }

  .hero {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .hero-content {
    max-width: 520px;
    padding: 0 2rem;
    pointer-events: auto;
  }

  h1 {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    color: var(--hero-text);
    text-shadow: var(--hero-shadow);
    margin-bottom: 1.5rem;
    transition: color 0.8s ease, text-shadow 0.8s ease;
  }

  .bio p {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(0.875rem, 1.8vw, 1.05rem);
    font-weight: 400;
    line-height: 1.7;
    color: var(--hero-text);
    text-shadow: var(--hero-shadow);
    max-width: none;
    transition: color 0.8s ease, text-shadow 0.8s ease;
  }

  .bio p + p {
    margin-top: 1rem;
  }

  @media (max-width: 600px) {
    .hero-content {
      padding: 0 1.5rem;
    }
  }
</style>
