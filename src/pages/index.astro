---
import Base from '../layouts/Base.astro';
---

<Base title="Clay Devlin" fullbleed>
  <div class="hero">
    <div class="hero-content">
      <div class="bio">
        <p>hello world. my name is clay devlin, and my website is under construction. check back soon :)</p>
      </div>
    </div>
  </div>
</Base>

<style>
  :global(body.fullbleed) {
    background: #fff;
    overflow: hidden;
  }

  :global(body.fullbleed main) {
    background: #fff;
    padding: 0;
  }

  :global(body.fullbleed .site-footer) {
    display: none;
  }

  .hero {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-content {
    max-width: 520px;
    padding: 0 2rem;
  }

  .bio p {
    font-family: 'BDO Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(0.875rem, 1.8vw, 1.05rem);
    font-weight: 400;
    line-height: 1.7;
    color: #1A1A1A;
    max-width: none;
  }

  @media (max-width: 600px) {
    .hero-content {
      padding: 0 1.5rem;
    }
  }
</style>
